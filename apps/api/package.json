{
  "name": "@stash/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx --env-file=../../.env prisma/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@stash/shared": "*",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.5.1",
    "fastify": "^4.28.0",
    "node-cron": "^4.6.0",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.15",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.22.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
