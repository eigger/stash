POSTGRES_USER=stash
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stash
POSTGRES_PORT=5433
DATABASE_URL=postgresql://stash:changeme@localhost:5433/stash

JWT_SECRET=changeme

# 아이템 상세페이지 딥링크(내부 발급 QR 라벨)에 사용하는 공개 URL. 프로덕션에서는
# 실제 접속 도메인으로 바꿔야 QR을 아무 카메라 앱으로 스캔해도 바로 열린다.
APP_PUBLIC_URL=http://localhost

# 최초 관리자 계정 (npm run seed -w apps/api 실행 시 사용)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin

# --- 아래는 선택 사항. 없어도 자체 발급 바코드/수동 입력만으로 전체 기능이 동작한다 ---

# UPCItemDB(https://www.upcitemdb.com) 조회 API 키. 없으면 Open Food Facts만 조회한다.
UPCITEMDB_API_KEY=

# 재고 이벤트 웹훅을 받을 URL (선택). 설정하면 아이템 생성/수정/수량조정/스캔 시 알림이 전송된다.
INVENTORY_WEBHOOK_URL=
